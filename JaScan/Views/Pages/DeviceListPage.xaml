<UserControl x:Class="JaScan.Views.Pages.DeviceListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16,12,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="복합기 관리" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>

            <!-- 추가 버튼 + 드롭다운 -->
            <Button x:Name="AddButton" Content="+ 추가" Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Right" Padding="14,6" FontSize="12"
                    Click="AddButton_Click"/>

            <Popup x:Name="AddPopup" PlacementTarget="{Binding ElementName=AddButton}"
                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                   HorizontalOffset="-60">
                <Border Background="White" CornerRadius="6" Padding="4"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,4,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                    </Border.Effect>
                    <StackPanel Width="150">
                        <Button Content="🔍  자동 검색" Style="{StaticResource LinkButton}"
                                HorizontalContentAlignment="Left" Padding="10,8"
                                FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                Click="AutoSearch_Click"/>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="6,0"/>
                        <Button Content="✏️  수동 연결 (IP)" Style="{StaticResource LinkButton}"
                                HorizontalContentAlignment="Left" Padding="10,8"
                                FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                Click="ManualConnect_Click"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>

        <!-- 빈 상태 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding HasDevices, Converter={StaticResource InverseBoolToVis}}">
            <TextBlock Text="🖨" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="등록된 복합기가 없습니다." FontSize="13"
                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="장치를 연결하여 스캔함을 추가하세요!" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 복합기 목록 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasDevices, Converter={StaticResource BoolToVis}}">
            <ItemsControl ItemsSource="{Binding Devices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="0,0,0,6" CornerRadius="6" Cursor="Hand"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Background="White">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.SelectDeviceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0">
                                        <Run Text="IP:"/>
                                        <Run Text="{Binding Ip, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border CornerRadius="8" Padding="8,3" Margin="0,0,6,0"
                                            Background="#EBF4EE">
                                        <TextBlock Text="연결됨" FontSize="10" Foreground="#1A7F37"/>
                                    </Border>
                                    <Button Content="✕" Style="{StaticResource IconButton}" Width="24" Height="24" FontSize="11"
                                            Command="{Binding DataContext.RemoveDeviceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
