<Window x:Class="JaScan.Views.Dialogs.DeviceSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="기기 검색" Width="380" Height="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize">

    <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Border Grid.Row="0" Padding="14,0" MouseLeftButtonDown="TitleBar_MouseDown"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="기기 검색" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Button Content="✕" Style="{StaticResource IconButton}"
                            HorizontalAlignment="Right" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- 결과 영역 -->
            <Grid Grid.Row="1" Margin="14,12">
                <!-- 검색 중 -->
                <StackPanel x:Name="SearchingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="160" Height="3"
                                 Foreground="{StaticResource PrimaryBrush}" Background="#E8EAF0"
                                 BorderThickness="0" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="SearchStatusText" Text="복합기를 검색하고 있습니다..."
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- 결과 목록 -->
                <ListBox x:Name="DeviceList" Visibility="Collapsed"
                         BorderThickness="0" Background="Transparent" SelectionMode="Single">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Margin="0,0,0,4" CornerRadius="5"
                                    Background="{StaticResource SurfaceBrush}" Cursor="Hand">
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0">
                                        <Run Text="IP:"/>
                                        <Run Text="{Binding Ip, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- 하단 -->
            <Border Grid.Row="2" Padding="14,10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock Text="수동으로 기기 연결하기" FontSize="11"
                               Foreground="{StaticResource PrimaryBrush}" Cursor="Hand"
                               VerticalAlignment="Center" MouseLeftButtonDown="ManualLink_Click">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="TextDecorations" Value="Underline"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button x:Name="NextButton" Content="다음" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right" Padding="18,7" FontSize="12"
                            Click="NextButton_Click" IsEnabled="False"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
