<Application x:Class="Scanlink.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Scanlink.Helpers"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Assets/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 컨버터 -->
            <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <helpers:StringEqualsConverter x:Key="StringEquals"/>
            <helpers:StringToVisibilityConverter x:Key="StringToVisibility"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
