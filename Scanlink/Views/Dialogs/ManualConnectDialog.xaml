<Window x:Class="Scanlink.Views.Dialogs.ManualConnectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="수동 연결" Width="340" Height="220"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize">

    <Border Background="White" CornerRadius="8" Padding="20,16"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <StackPanel>
            <Grid Margin="0,0,0,14">
                <TextBlock Text="수동으로 기기 연결" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <Button Content="✕" Style="{StaticResource IconButton}"
                        HorizontalAlignment="Right" Click="CloseButton_Click"/>
            </Grid>

            <TextBlock Text="복합기 IP 주소" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="IpTextBox" Style="{StaticResource ModernTextBox}" MaxLength="15"/>

            <TextBlock x:Name="ErrorText" Text="" FontSize="11"
                       Foreground="{StaticResource ErrorBrush}" Margin="0,4,0,0"/>

            <Grid Margin="0,16,0,0">
                <Button Content="취소" Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left" Click="CloseButton_Click"/>
                <Button Content="연결" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right" Padding="20,7"
                        Click="ConnectButton_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
