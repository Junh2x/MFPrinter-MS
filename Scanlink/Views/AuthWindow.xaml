<Window x:Class="Scanlink.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scanlink" Width="360" Height="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize">

    <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 타이틀바 -->
            <Border Grid.Row="0" Padding="12,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="Scanlink" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                    <Button Content="✕" Style="{StaticResource IconButton}"
                            HorizontalAlignment="Right" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- 본문 -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="32,0">

                <TextBlock Text="Scanlink" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="스캔함 관리 프로그램" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <TextBlock Text="인증 키" FontSize="12" FontWeight="Medium"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="30">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding VerifyCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <TextBlock Text="{Binding ErrorMessage}" FontSize="11"
                           Foreground="{StaticResource ErrorBrush}" Margin="0,6,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                <Button Content="인증하기" Style="{StaticResource PrimaryButton}"
                        Command="{Binding VerifyCommand}" Margin="0,20,0,0"
                        HorizontalAlignment="Stretch" Height="38"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
