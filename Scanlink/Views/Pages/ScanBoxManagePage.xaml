<UserControl x:Class="Scanlink.Views.Pages.ScanBoxManagePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,12,16,16">

            <Button Content="← 스캔함 목록" Style="{StaticResource LinkButton}"
                    HorizontalAlignment="Left" FontSize="12" Margin="0,0,0,12"
                    Command="{Binding GoBackCommand}"/>

            <TextBlock Text="스캔함 설정" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

            <!-- 스캔함 이름 -->
            <TextBlock Text="스캔함 이름 *" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Name}" Margin="0,0,0,12"/>

            <!-- 비밀번호 -->
            <TextBlock Text="비밀번호" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Password}" Margin="0,0,0,16"/>

            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,16"/>

            <!-- 저장 설정 -->
            <TextBlock Text="저장 설정" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

            <TextBlock Text="저장 경로" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}"
                         Text="{Binding LocalFolder}" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="📁" Style="{StaticResource SecondaryButton}"
                        Margin="4,0,0,0" Padding="0" Width="30" Height="30"
                        Command="{Binding BrowseFolderCommand}"/>
            </Grid>

            <TextBlock Text="파일 삭제 주기" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding DeleteCycles}" SelectedItem="{Binding DeleteCycle}" Margin="0,0,0,20"/>

            <!-- 버튼 / 로딩 -->
            <Grid>
                <Grid x:Name="ButtonPanel" Visibility="{Binding IsSaving, Converter={StaticResource InverseBoolToVis}}">
                    <Button Content="폴더 열기" Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left" Command="{Binding OpenFolderCommand}"/>
                    <Button Content="저장" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right" Padding="24,0"
                            Command="{Binding SaveCommand}"/>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="3"
                                 Foreground="{StaticResource PrimaryBrush}" Background="#E8EAF0"
                                 BorderThickness="0"/>
                    <TextBlock Text="저장 중..." FontSize="12" Margin="10,0,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
