<Window x:Class="Scanlink.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Scanlink.ViewModels"
        xmlns:pages="clr-namespace:Scanlink.Views.Pages"
        Title="Scanlink" Width="380" Height="580"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 타이틀바 -->
            <Border Grid.Row="0" Padding="14,0" MouseLeftButtonDown="TitleBar_MouseDown"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Scanlink" Foreground="{StaticResource PrimaryBrush}"
                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource IconButton}" Click="MinimizeButton_Click" FontSize="11"/>
                        <Button Content="✕" Style="{StaticResource IconButton}" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 페이지 콘텐츠 -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentPage}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:DeviceListViewModel}">
                        <pages:DeviceListPage/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ScanBoxListViewModel}">
                        <pages:ScanBoxListPage/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ScanBoxManageViewModel}">
                        <pages:ScanBoxManagePage/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>

        </Grid>
    </Border>
</Window>
